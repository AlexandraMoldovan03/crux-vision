{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "crux-vision.com" }],
      "destination": "https://www.crux-vision.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "cruxvision.ro" }],
      "destination": "https://www.crux-vision.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.cruxvision.ro" }],
      "destination": "https://www.crux-vision.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
